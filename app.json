{
  "expo": {
    "name": "Reminders",
    "slug": "reminders-tool",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "reminders-tool",
    "icon": "./assets/images/icon.png",
    "android": {
      "backgroundColor": "#000000",
      "package": "com.im360noscope.reminderstool"
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/PublicSans-Regular.ttf"
          ]
        }
      ],
      "./plugins/withAndroidConfigChanges",
      "./plugins/withAndroidTheme"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {}
    }
  }
}
